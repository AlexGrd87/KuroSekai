# Copie ce fichier en .env et remplis les valeurs

# ── Serveur (Render) ──────────────────────────────
# Clé secrète pour signer les tokens JWT — change cette valeur !
JWT_SECRET=change-moi-en-quelque-chose-de-long-et-aléatoire

# Origins autorisés (séparés par des virgules)
# Mets l'URL de ton GitHub Pages ici
ALLOWED_ORIGINS=http://localhost:5173,https://TON_PSEUDO.github.io

# Port du serveur (Render le définit automatiquement)
PORT=3001

# Chemin de la base de données SQLite
# Sur Render : utilise un Persistent Disk monté sur /data
# DB_PATH=/data/kuro.db
